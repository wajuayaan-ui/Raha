<script>
  window.addEventListener("load", function () {
    const rotateImg = document.getElementById('img-rotate-me');
    let currentRotation = 0;

    if (rotateImg) {
      rotateImg.addEventListener('wheel', (event) => {
        event.preventDefault(); // Prevent page scroll

        // Only respond to vertical scroll
        if (event.deltaY !== 0) {
          const direction = event.deltaY > 0 ? 1 : -1;
          currentRotation += direction * 22; // Step size: 15 degrees

          rotateImg.style.transform = `rotateY(${currentRotation}deg)`;
        }
      }, { passive: false });
    } else {
      console.warn('Element with id "img-rotate-me" not found.');
    }
  });
</script>

<script>
  window.addEventListener("load", function () {
    const rotateImg = document.getElementById('img-rotate-me');

    if (!rotateImg) {
      console.warn('Element with id "img-rotate-me" not found.');
      return;
    }

    // Optional: store the last scroll position to calculate delta
    let lastScrollY = window.scrollY;

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const scrollDelta = scrollY - lastScrollY;
      lastScrollY = scrollY;

      // Calculate rotation amount (tweak multiplier to control sensitivity)
      const rotationChange = scrollDelta * 0.5; // Change 0.5 to adjust sensitivity

      // Read current rotation from data attribute or fallback
      let currentRotation = parseFloat(rotateImg.getAttribute('data-rotation')) || 0;
      currentRotation += rotationChange;
      /*
      if (currentRotation > 180)
          currentRotation = 180;
      if (currentRotation < -180)
          currentRotation = -180;
      */

      // Store and apply the new rotation
      rotateImg.setAttribute('data-rotation', currentRotation);
      rotateImg.style.transform = `rotateY(${currentRotation}deg)`;
    });
  });
</script>

