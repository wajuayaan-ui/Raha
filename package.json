{
  "name": "raha-quotation",
  "version": "1.0.7",
  "description": "Raha Co. Quotation System",
  "author": "Wajahat Ali",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.rahaco.quotation",
    "copyright": "Wajahat Ali",
    "productName": "Raha Quotation",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "quotation.html",
      "contract.html",
      "deliverynote.html",
      "purchaseorder.html",
      "product-assistant.html",
      "firebase-config.json"
    ],
    "extraResources": [
      {
        "from": "Logo",
        "to": "Logo"
      },
      {
        "from": "data",
        "to": "data"
      },
      {
        "from": "ProductImages",
        "to": "ProductImages"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "wajuayaan-ui",
        "repo": "RahaQuotation",
        "private": false
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "Logo/logo.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "firebase-admin": "^12.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}
